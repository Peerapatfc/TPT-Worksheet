OPENAI_API_KEY=sk-...
GOOGLE_DRIVE_FOLDER_ID=<from Drive URL /folders/{ID}>
# Flat folder linked to TPT — only combined PDF uploaded here (no PNGs/JSON/TXT)
GOOGLE_DRIVE_TPT_FOLDER_ID=<from Drive URL /folders/{ID}>
GOOGLE_OAUTH_CLIENT_ID=<OAuth2 client ID from Google Cloud Console>
GOOGLE_OAUTH_CLIENT_SECRET=<OAuth2 client secret>
GOOGLE_OAUTH_REFRESH_TOKEN=<run: node scripts/get-refresh-token.js>
TELEGRAM_BOT_TOKEN=123456789:ABCDEF...
TELEGRAM_CHANNEL_ID=-1001234567890
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# GRADE_LEVEL options:
#   specific: "Grade 3"
#   range:    "Grade 1-5"  (AI picks best within range)
#   omit:     AI picks any grade Kindergarten-Grade 6
GRADE_LEVEL=
# Package tiers — structure: 1 cover + N worksheets + N answer_keys = 1+2N pages (always odd)
#   free:  N=1–3,  total 3–7 pages,   price $0    (FREE_WORKSHEET_DAY)
#   small: N=5–9,  total 11–19 pages,  price $2–5  (all other days)
#   large: N=10+,  total 21–MAX pages, price $5–15  (LARGE_PACKAGE_DAY)
MAX_PAGES_PER_SET=30
# Day of week to publish a free worksheet (0=Sun, 1=Mon, ..., 6=Sat). Default: 0 (Sunday)
FREE_WORKSHEET_DAY=0
# Day of week to publish a large package. Omit to never run large.
LARGE_PACKAGE_DAY=
